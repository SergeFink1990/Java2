import java.util.ArrayList;

// Родительский класс
class Animal {
    protected String name;
    protected int age;

    public Animal(String name, int age) {
        this.name = name;
        this.age = age;
    }

    public void makeSound() {
        System.out.println("Животное издаёт звук");
    }
    
    public void info() {
        System.out.println("Имя: " + name + ", Возраст: " + age + " лет");
    }
}

// Дочерний класс Dog
class Dog extends Animal {
    private String breed;
    
    public Dog(String name, int age, String breed) {
        super(name, age);
        this.breed = breed;
    }

    @Override
    public void makeSound() {
        System.out.println("Гав-гав!");
    }
    
    @Override
    public void info() {
        System.out.println("Имя: " + name + ", Возраст: " + age + " лет, Порода: " + breed);
    }
}

// Дочерний класс Cat
class Cat extends Animal {
    public Cat(String name, int age) {
        super(name, age);
    }

    @Override
    public void makeSound() {
        System.out.println("Мяу!");
    }
}

// Новый класс Bird
class Bird extends Animal {
    public Bird(String name, int age) {
        super(name, age);
    }

    @Override
    public void makeSound() {
        System.out.println("Кар-кар!");
    }
}

// Точка входа
public class InheritancePractice {
    public static void main(String[] args) {
        // Создание объектов
        Dog dog = new Dog("Бобик", 3, "Овчарка");
        Cat cat = new Cat("Мурка", 2);
        Bird bird = new Bird("Кеша", 1);
        
        // Вызов методов
        dog.makeSound();
        cat.makeSound();
        bird.makeSound();
        
        // Информация о животных
        dog.info();
        cat.info();
        bird.info();
        
        // ArrayList с животными
        ArrayList<Animal> animals = new ArrayList<>();
        animals.add(dog);
        animals.add(cat);
        animals.add(bird);
        
        System.out.println("\nВывод звуков всех животных из списка:");
        for (Animal animal : animals) {
            animal.makeSound();
        }
    }
}
